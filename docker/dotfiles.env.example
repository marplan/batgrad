# Optional: enable personal dotfiles bootstrap during setup. 0 = disabled, 1 = enabled.
ENABLE_DOTFILES=0
# URL of the dotfiles repo to clone.
DOTFILES_REPO=
# Branch of the dotfiles repo to clone.
DOTFILES_REF=main
# Directory where the dotfiles repo will be cloned to. Pls do not change this.
DOTFILES_DIR=/home/ubuntu/dotfiles

# DOTFILES_SETUP_CMD runs from DOTFILES_DIR after dotfiles are cloned into the container.
DOTFILES_SETUP_CMD=
