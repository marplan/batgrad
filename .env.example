# Setup by user
# Host data root that gets mounted into the container at /data.
HOST_DATA_ROOT=/path/to/data

# Optional 1Password token for CLI workflows.
OP_SERVICE_ACCOUNT_TOKEN=

# Optional: local Docker Desktop default shown here. On remote hosts, use $SSH_AUTH_SOCK.
SSH_AUTH_SOCK_HOST=/run/host-services/ssh-auth.sock

# Defaults
# Host user/group ids used for the ubuntu container user.
HOST_UID=1000
HOST_GID=1000

# Runtime data root loaded by `uv run` and project key used for container paths.
DATA_ROOT=/data
PROJECT_KEY=batgrad

# uv automatically loads this file for `uv run` commands.
UV_ENV_FILE=.env
