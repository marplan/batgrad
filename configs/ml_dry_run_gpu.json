{
  "data": {
    "manifest_paths": {
      "type=synthetic/dataset=synthetic-pozzato-2022-m50t/source=normalized/manifest.parquet": "1f5c354"
    },
    "protocols": ["cycling"],
    "input_columns": [
      "Time diff [s]",
      "Current [C-rate]",
      "Terminal voltage [V]"
    ],
    "target_columns": ["Terminal voltage [V]", "Surface temperature [degC]"],
    "feedback_columns": ["Terminal voltage [V]"],
    "scaling": [
      {"column": "Time diff [s]", "input_min": 0.0, "input_max": 10000.0, "transform": "log1p"},
      {"column": "Current [C-rate]", "input_min": -6.0, "input_max": 6.0},
      {"column": "Terminal voltage [V]", "input_min": 2.3, "input_max": 4.6},
      {"column": "Surface temperature [degC]", "input_min": 5.0, "input_max": 65.0}
    ]
  },
  "loader": {
    "batch_size": 8,
    "seq_len": 512,
    "strategy": "sequential",
    "stateful_n_windows": 1,
    "data_access": "windowed",
    "num_workers": 0,
    "prefetch_to_device": false
  },
  "model": {
    "d_model": 128,
    "n_heads": 4,
    "mlp_ratio": 4.0,
    "dropout": 0.0,
    "norm": "rmsnorm",
    "causal_attention": true,
    "num_bins": 64,
    "input_sigma": 0.0,
    "output_sigma": 0.0,
    "feedback_mode": "probabilities",
    "mamba": {
      "d_state": 64,
      "expand": 2,
      "headdim": 64,
      "ngroups": 1,
      "is_mimo": false,
      "mimo_rank": 1,
      "chunk_size": 64
    },
    "layers": [
      {"kind": "reduce", "mode": "sum_pool", "residual": false},
      {"kind": "attention"},
      {"kind": "mamba", "residual": {"kind": "standard"}},
      {"kind": "attention"},
      {"kind": "mamba", "residual": {"kind": "standard"}}
    ],
    "head_layers": [
      {"kind": "attention"},
      {"kind": "ffn"}
    ],
    "output": {"parameterization": "shared"}
  },
  "train": {
    "epochs": 1.0,
    "max_steps": 150,
    "log_every_steps": 10,
    "validate_every_steps": 100,
    "loss": "categorical_ce",
    "grad_clip_norm": 1.0,
    "masked_suffix": {
      "enabled": true,
      "channels": ["Terminal voltage [V]"],
      "suffix_steps": 128,
      "fill_value": 0.0,
      "loss_on_masked_only": true,
      "carry_mamba_state": false,
      "detach_between_windows": true,
      "roll_forward_steps": 128
    }
  },
  "validation": {
    "split": {
      "strategy": "merge",
      "fraction": 0.2,
      "group_by": ["dataset id", "cell id", "cycle index", "protocol"],
      "groups": [
        {
          "match": {
            "dataset id": "synthetic-pozzato-2022-m50t",
            "cell id": "M50T_T10C_CR025_A005_S0001",
            "cycle index": 1,
            "protocol": "cycling"
          },
          "rollout_start_offsets": [1024]
        }
      ]
    },
    "max_tf_batches": 1,
    "rollout_steps": 64,
    "log_rollout_plots": true,
    "rollout_extension": {
      "enabled": false,
      "steps": 0,
      "input_values": {
        "Time diff [s]": 100.0,
        "Current [C-rate]": 0.5
      }
    }
  },
  "optim": {
    "kind": "adamw",
    "lr": 0.001,
    "weight_decay": 0.0,
    "beta1": 0.9,
    "beta2": 0.95,
    "eps": 1e-8
  },
  "scheduler": {
    "kind": "linear_warmup_cosine",
    "warmup_ratio": 0.2,
    "min_lr_ratio": 0.1
  },
  "run": {
    "device": "cuda",
    "use_amp": true,
    "compile_model": false,
    "output_dir": null,
    "name": "dry-run-gpu"
  },
  "logging": {"backend": "stdout"},
  "checkpoint": {"enabled": false},
  "seed": 69
}
